---
// Navbar compartido para toda la aplicación
interface Props {
  username?: string;
  rol?: string;
}

const { username, rol } = Astro.props;
---

<nav class="navbar">
  <div class="container">
    <div class="navbar-brand">
      <a href="/dashboard" class="logo">
        💳 WalletUp
      </a>
    </div>

    <div class="navbar-menu">
      <div class="navbar-start">
        {rol === 'cliente' && (
          <>
            <a href="/dashboard" class="navbar-item">Dashboard</a>
            <a href="/transacciones" class="navbar-item">Transacciones</a>
            <a href="/categorias" class="navbar-item">Categorías</a>
            <a href="/metas" class="navbar-item">Metas</a>
            <a href="/reportes" class="navbar-item">Reportes</a>
            <a href="/educacion" class="navbar-item">Educación</a>
          </>
        )}

        {rol === 'superadmin' && (
          <>
            <a href="/dashboard" class="navbar-item">Dashboard</a>
            <a href="/admin/usuarios" class="navbar-item">Usuarios</a>
            <a href="/admin/reportes" class="navbar-item">Reportes</a>
            <a href="/admin/logs" class="navbar-item">Logs</a>
          </>
        )}
      </div>

      <div class="navbar-end">
        <div class="navbar-item user-info">
          <span class="user-name">{username}</span>
          <span class="user-rol">{rol}</span>
        </div>
        <a href="/logout" class="btn btn-outline btn-sm">Logout</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    background-color: var(--dark-bg);
    color: var(--white);
    padding: 1rem 0;
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .navbar-brand {
    flex-shrink: 0;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .navbar-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: space-between;
  }

  .navbar-start,
  .navbar-end {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .navbar-item {
    color: var(--white);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    transition: var(--transition);
  }

  .navbar-item:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .user-name {
    font-weight: 600;
  }

  .user-rol {
    font-size: 0.85rem;
    opacity: 0.8;
    text-transform: uppercase;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .navbar .container {
      flex-direction: column;
      gap: 1rem;
    }

    .navbar-menu {
      width: 100%;
      flex-direction: column;
      gap: 1rem;
    }

    .navbar-start {
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
    }

    .navbar-end {
      width: 100%;
      justify-content: space-between;
    }

    .user-info {
      align-items: flex-start;
    }
  }
</style>
